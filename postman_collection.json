{
	"info": {
		"name": "Helpdesk Ticketing API",
		"description": "API documentation for the Helpdesk Ticketing System (MERN Stack).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@test.com\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/v1/auth/register",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5000",
							"path": ["api", "v1", "auth", "register"]
						}
					}
				},
				{
					"name": "Login User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@test.com\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/v1/auth/login",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5000",
							"path": ["api", "v1", "auth", "login"]
						}
					}
				}
			]
		},
		{
			"name": "Tickets",
			"item": [
				{
					"name": "Get All Tickets",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN_HERE" }
						],
						"url": {
							"raw": "http://localhost:5000/api/v1/tickets?page=1&limit=10",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5000",
							"path": ["api", "v1", "tickets"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "limit", "value": "10" }
							]
						}
					}
				},
				{
					"name": "Create Ticket",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN_HERE" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Cannot access database\",\n    \"description\": \"I am getting a timeout error when querying the cluster.\",\n    \"category\": \"Bug Report\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/v1/tickets",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5000",
							"path": ["api", "v1", "tickets"]
						}
					}
				},
				{
					"name": "Update Ticket Status (Admin)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer YOUR_ADMIN_JWT_HERE" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"In Progress\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/api/v1/tickets/TICKET_ID_HERE",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5000",
							"path": ["api", "v1", "tickets", "TICKET_ID_HERE"]
						}
					}
				},
				{
					"name": "Delete Ticket (Admin)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Authorization", "value": "Bearer YOUR_ADMIN_JWT_HERE" }
						],
						"url": {
							"raw": "http://localhost:5000/api/v1/tickets/TICKET_ID_HERE",
							"protocol": "http",
							"host": ["localhost"],
							"port": "5000",
							"path": ["api", "v1", "tickets", "TICKET_ID_HERE"]
						}
					}
				}
			]
		}
	]
}